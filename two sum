#include <bits/stdc++.h>
using namespace std;

class solution {
   public:
    vector<int> twoSum(vector<int>& arr, int k) {
       unordered_map <int,int> mp ; 
       int n = arr.size(); 
       for(int i = 0 ; i < n ;i++){
           int sum = k - arr[i] ; 
           if(mp.find(sum)!=mp.end()){
               return {mp[sum],i}; 
           }
           mp[arr[i]] = i ; 
       }
        return {-1,-1} ; 
        
    }
}; 
